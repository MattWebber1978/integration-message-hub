package.xml

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**

node_modules/

# Profiles - too org-specific to version control cleanly
profiles/

# Standard objects - we only want our custom objects in source control
standardObjects/

# Debug logs
*.log

# OS files
.DS_Store
Thumbs.db